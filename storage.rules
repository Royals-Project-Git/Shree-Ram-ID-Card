rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Submission photos — anyone can upload (public form), only auth can read
    match /submissions/{submissionId}/{allPaths=**} {
      allow write: if true;           // public form uploads photo
      allow read:  if request.auth != null;
    }

    // Org logos — only logged-in users
    match /org-logos/{allPaths=**} {
      allow read:  if true;           // logos shown on public form page
      allow write: if request.auth != null;
    }

    // Card backgrounds — only logged-in users
    match /backgrounds/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
